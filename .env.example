# Social SHM Backend - Environment Configuration
# Copy this to .env and fill in actual values

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/social_shm
DB_HOST=localhost
DB_PORT=5432
DB_NAME=social_shm
DB_USER=postgres
DB_PASSWORD=

# Server
NODE_ENV=development
PORT=3000

# Signal Processing Thresholds
MIN_FREQUENCY_HZ=0.5
MAX_FREQUENCY_HZ=20
JERK_OUTLIER_THRESHOLD_SIGMA=5
BASELINE_TRIP_COUNT=30

# Health Score Thresholds
RED_ALERT_FREQ_SHIFT_SIGMA=2.0
RED_ALERT_VARIANCE_MULTIPLIER=1.5
YELLOW_ALERT_FREQ_SHIFT_SIGMA=1.0
YELLOW_ALERT_VARIANCE_MULTIPLIER=2.0

# API Limits
MAX_UPLOAD_SIZE_MB=50
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# Logging
LOG_LEVEL=info
